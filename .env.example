# Start.gg API Configuration

# Get your API token from: https://start.gg/admin/profile/developer
# 1. Visit the link above (requires a start.gg account)
# 2. Click "Create new token"
# 3. Enter a description for your token
# 4. Copy the generated token and paste it below

EXPO_PUBLIC_START_GG_API_TOKEN=your_start_gg_api_token_here

# Example:
# EXPO_PUBLIC_START_GG_API_TOKEN=abcd1234567890abcdef1234567890abcdef12

# Note: This token allows read-only access to public tournament data
# Keep this token secure and do not share it publicly