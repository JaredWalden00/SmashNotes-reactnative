{
  "name": "smashnotes-reactnative",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "docker:web:build": "docker compose build expo-web",
    "docker:web:up": "docker compose up expo-web",
    "docker:web:down": "docker compose down",
    "dev:docker:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-docker-up.ps1",
    "dev:docker:down": "docker compose down && npx supabase stop",
    "db:init": "npx supabase init",
    "db:link": "npx supabase link",
    "db:migration:new": "npx supabase migration new",
    "db:migrate": "npx supabase db push",
    "db:types": "npx supabase gen types typescript --linked --schema public"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@supabase/supabase-js": "^2.99.3",
    "expo": "^54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "supabase": "^2.83.0"
  }
}
